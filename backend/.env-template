# Configurações do Backend do webServerDatabaseEditor

# Caminho absoluto ou relativo para o seu banco de dados de itens (item_db.yml)
# Exemplo Windows: X:\caminho\para\seu\item_db.yml
ITEM_DB_PATH=

# Caminho absoluto ou relativo para o arquivo GRF do client do jogo
# Exemplo Windows: X:\caminho\para\data.grf ou X:\caminho\para\data\ (pasta extraída da GRF)
GRF_PATH=

# Pasta onde salvar novos assets (ícones e sprites) quando GRF_PATH aponta para um .grf binário.
# Se GRF_PATH já for uma pasta, este campo é ignorado (a pasta do GRF é usada diretamente).
# Opcional — defina GRF_OVERRIDE_PATH no seu .env se precisar.
# Exemplo Windows: X:\caminho\para\pasta_override\data
# GRF_OVERRIDE_PATH=

# Caminho para o System/iteminfo.lua do seu client
ITEMINFO_PATH=

# Origens permitidas do CORS separadas por vírgula (Exemplo: http://localhost:5173)
CORS_ORIGINS=

# Caminho para o banco de habilidades (skill_db.yml)
SKILL_DB_PATH=

# Caminho para o banco de skills de monstros (mob_skill_db.txt)
MOB_SKILL_DB_PATH=

# Caminho para o banco de combos de itens (item_combos.yml)
COMBO_DB_PATH=

# Caminho para o banco de quests (quest_db.yml)
QUEST_DB_PATH=

# Caminho para o banco de mascotes (pet_db.yml)
PET_DB_PATH=