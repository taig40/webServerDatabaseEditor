# Configurações do Backend do webServerDatabaseEditor
# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores.
# Você também pode gerenciar tudo pela página de Configurações (⚙) do site.

# ── Banco de Dados do Servidor ────────────────────────────────────────────────

# Caminho base para a pasta de banco de dados do servidor
# Ex: C:\rathena\db  (os arquivos serão buscados em <base>/re/ e /import/)
SERVER_DB_BASE_PATH=

# ── Cliente ───────────────────────────────────────────────────────────────────

# Caminho para o System/iteminfo.lua do seu client RO
ITEMINFO_PATH=
ACHIEVEMENTS_LUA_PATH=
QUESTS_LUA_PATH=

# ── GRF Files (DATA.INI style — até 10 arquivos) ─────────────────────────────
# GRF_0 tem a MAIOR prioridade (sobrescreve as demais), GRF_9 a MENOR.
# Siga a mesma ordem do seu DATA.INI.
GRF_0=
GRF_1=
GRF_2=
GRF_3=
GRF_4=
GRF_5=
GRF_6=
GRF_7=
GRF_8=
GRF_9=

# Pasta de override — onde o editor salva sprites/ícones customizados.
# Obrigatório ao usar GRF binários. Deve apontar para uma pasta (ex: C:\kRO\data\)
GRF_OVERRIDE_PATH=

# ── Encoding ──────────────────────────────────────────────────────────────────

# Encoding dos arquivos de texto do SERVIDOR (mob_skill_db.txt, etc.)
# Opções: utf-8 (padrão rAthena), euc-kr (servidores coreanos), cp1252 (Windows ocidental)
SERVER_ENCODING=utf-8

# Encoding dos arquivos do CLIENTE (itemInfo.lua, nomes de arquivos na GRF, etc.)
# Opções: euc-kr (kRO / clientes coreanos), utf-8 (clientes modernos), cp1252 (Windows ocidental)
CLIENT_ENCODING=euc-kr

# ── Avançado ──────────────────────────────────────────────────────────────────

# Origens permitidas do CORS separadas por vírgula
CORS_ORIGINS=
